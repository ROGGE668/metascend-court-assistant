{
  "build": {
    "frontendDist": "../dist/frontend",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "productName": "Metascend Court Assistant",
  "version": "0.2.0",
  "identifier": "com.metascend.court-assistant",
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Metascend 庭审助手",
        "url": "../dist/frontend/index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
