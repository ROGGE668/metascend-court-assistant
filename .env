# Audio settings
SAMPLE_RATE=16000
CHANNELS=1
CHUNK_DURATION_MS=100
VAD_AGGRESSIVENESS=2

# ASR settings
ASR_MODEL_SIZE=base
ASR_DEVICE=auto
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=zh
ASR_BEAM_SIZE=5

# Hotwords (comma separated, no spaces)
ASR_HOTWORDS=借贷,离婚,劳动,合同

# Diarization (Phase 2)
ENABLE_DIARIZATION=true
DIARIZATION_BACKEND=pyannote
DIARIZATION_SIMILARITY_THRESHOLD=0.65
DIARIZATION_ROLE_THRESHOLD=0.60
DIARIZATION_MAX_SPEAKERS=4

# Legal assistant (Phase 3)
ENABLE_LEGAL_ASSISTANT=true
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
KNOWLEDGE_BASE_DIR=./data/knowledge_base
TEMPLATES_DIR=./data/templates
LLM_TIMEOUT=10.0

# TTS (Phase 4)
ENABLE_TTS=false
TTS_BACKEND=system
TTS_VOICE=Ting-Ting
TTS_VOLUME=0.8
TTS_DUCKING=true

# Recording & privacy (Phase 5)
ENABLE_RECORDING=false
ENABLE_ENCRYPTED_LOGS=false
# Leave empty to use an insecure default; set a strong passphrase for real use.
RECORDING_PASSWORD=

# UI settings
UI_WINDOW_OPACITY=0.85
UI_FONT_SIZE=17
UI_MAX_LINES=5

# OCR
ENABLE_OCR_FALLBACK=true

# Paths
MODEL_CACHE_DIR=~/.cache/metascend/models
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO

# Hugging Face mirror (useful in China, e.g. https://hf-mirror.com)
# HF_ENDPOINT=https://hf-mirror.com
